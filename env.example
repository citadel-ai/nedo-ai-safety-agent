# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Langfuse v3 Configuration (for observability)
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_HOST=https://cloud.langfuse.com  # or your self-hosted instance

# Observability Control
LANGFUSE_ENABLED=true  # Set to 'false' to disable Langfuse and run without observability

# Optional: Custom model configuration
VERTEX_AI_LOCATION=us-central1
MODEL_NAME=gemini-2.5-flash

# Vector Database Configuration
EMBEDDING_PROVIDER=sentence_transformers  # or 'google' for Google embeddings
GOOGLE_API_KEY=your-google-api-key  # Required for Google embeddings

# Google Search Configuration (optional - falls back to mock)
GOOGLE_CSE_ID=your-custom-search-engine-id  # Free option with GOOGLE_API_KEY
# Note: For best results, use ADK's built-in google_search tool instead
# Without API keys, system will fall back to mock search

# Development
PYTHONPATH=.
DEBUG=true
